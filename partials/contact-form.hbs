{{!-- Contact form --}}
<form class="fs-contact-form" method="POST" action="#" data-webhook="{{@custom.contact_webhook_url}}" data-success="{{@custom.contact_success_message}}" data-error="{{@custom.contact_error_message}}">
          <div class="fs-contact-grid">
            <label class="fs-contact-field">
              <span class="fs-contact-label">Name</span>
              <input class="fs-contact-input" type="text" name="name" autocomplete="name" required>
            </label>

            <label class="fs-contact-field">
              <span class="fs-contact-label">Email</span>
              <input class="fs-contact-input" type="email" name="email" autocomplete="email" required>
            </label>
          </div>

          <label class="fs-contact-field">
            <span class="fs-contact-label">Subject</span>
            <input class="fs-contact-input" type="text" name="subject" required>
          </label>

          <label class="fs-contact-field">
            <span class="fs-contact-label">Message</span>
            <textarea class="fs-contact-textarea" name="message" rows="6" required></textarea>
          </label>

          {{!-- Honeypot: hidden from humans, bots fill it --}}
          <input type="text" name="website" class="fs-contact-honey" tabindex="-1" autocomplete="off">

          {{!-- Time trap: JS sets this on load, elapsed calculated on submit --}}
          <input type="hidden" name="_ts" value="">

          <button class="fs-btn fs-contact-submit" type="submit">Send message</button>

          <div class="fs-contact-status" role="status" aria-live="polite"></div>
        </form>
