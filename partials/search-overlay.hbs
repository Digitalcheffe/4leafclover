{{!-- Search overlay --}}
<div id="fs-search-overlay" class="fs-search-overlay"
  role="dialog" aria-modal="true" aria-label="Search"
  data-api-key="{{content_api_key}}"
  data-api-url="{{@site.url}}">
  <div class="fs-search-backdrop" aria-hidden="true"></div>
  <div class="fs-search-modal">
    <div class="fs-search-bar">
      <span class="fs-search-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </span>
      <input id="fs-search-input" class="fs-search-input" type="search"
        placeholder="Search posts, pages, tags…"
        autocomplete="off" autocorrect="off" spellcheck="false"
        aria-label="Search query">
      <button class="fs-search-close" type="button" aria-label="Close search">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div id="fs-search-results" class="fs-search-results" role="listbox" aria-label="Search results" aria-live="polite"></div>
  </div>
</div>
