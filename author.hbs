{{!< default}}

<main class="fs-main">
  <div class="fs-grid" style="align-items:start;">

    <article class="fs-content-card">
      <div class="fs-content-wrap">

          {{#author}}
<header class="fs-post-header">
            <nav class="fs-breadcrumbs" aria-label="Breadcrumb">
              <a class="fs-crumb" href="{{@site.url}}">Home</a>
              <span class="fs-crumb-sep">/</span>
              <span class="fs-crumb-current">{{name}}</span>
            </nav>
          </header>

          {{!-- Author card (matches post.hbs author card; larger avatar on author page) --}}
<section class="fs-author-card fs-author-card--profile" aria-label="About the author" style="margin-top:1.25rem;">
  <div class="fs-author-card__inner" aria-label="About author {{name}}">

    {{!-- Whole card link (social icons sit above this layer and remain clickable) --}}
    <a class="fs-author-card__overlay-link" href="{{url}}" aria-label="View author {{name}}"></a>

    {{#if profile_image}}
      <div class="fs-author-card__photo fs-author-card__pe-none">
        <img src="{{img_url profile_image size="m"}}" alt="{{name}}">
      </div>
    {{/if}}

    <div class="fs-author-card__body fs-author-card__pe-none">
      <div class="fs-author-card__eyebrow">Author</div>
      <h3 class="fs-author-card__name">{{name}}</h3>
      {{#if bio}}
        <p class="fs-author-card__bio">{{bio}}</p>
      {{/if}}
    </div>

    {{!-- Social icons (only shows populated profiles) --}}
    <div class="fs-author-card__socials">
      {{> "author-socials"}}
    </div>

    {{#if cover_image}}
      <div class="fs-author-card__cover" aria-hidden="true" style="background-image:url('{{img_url cover_image size="m"}}')"></div>
    {{/if}}
  </div>
</section>
{{/author}}

{{!-- Bridge: Latest • Field Notes --}}
        <div class="fs-section-bridge fs-section-bridge--between" aria-hidden="true">
          <div class="fs-section-bridge__inner">
            <span class="fs-bridge-line"></span>
            <span class="fs-bridge-word">Latest</span>
            <span class="fs-bridge-dot"></span>
            <span class="fs-bridge-word">Field Notes</span>
            <span class="fs-bridge-line"></span>
          </div>
        </div>

        {{!-- Latest 10 posts by this author, using same layout as home/tag --}}
        <div class="fs-feed-horizontal">
          {{#foreach posts limit="10"}}
            {{> "post-row"}}
          {{/foreach}}
        </div>

      </div>
    </article>

    <aside class="fs-sidebar" {{#if @custom.sidebar_sticky}}style="position:sticky;top:5.5rem;align-self:start;"{{/if}}>
      {{> "sidebar"}}
    </aside>

  </div>
</main>
