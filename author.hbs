{{!< default}}

<main class="fs-main">
  <div class="fs-grid">

    <article class="fs-content-card">
      <div class="fs-content-wrap">

          {{#author}}
<header class="fs-post-header">
            <nav class="fs-breadcrumbs" aria-label="Breadcrumb">
              <a class="fs-crumb" href="{{@site.url}}">Home</a>
              <span class="fs-crumb-sep">/</span>
              <span class="fs-crumb-current">{{name}}</span>
            </nav>
          </header>

          {{> "author-card"}}
{{/author}}

{{!-- Bridge: Latest • Field Notes --}}
        <div class="fs-section-bridge fs-section-bridge--between" aria-hidden="true">
          <div class="fs-section-bridge__inner">
            <span class="fs-bridge-line"></span>
            <span class="fs-bridge-word">Latest</span>
            <span class="fs-bridge-dot"></span>
            <span class="fs-bridge-word">Field Notes</span>
            <span class="fs-bridge-line"></span>
          </div>
        </div>

        {{!-- Latest 10 posts by this author, using same layout as home/tag --}}
        <div class="fs-feed-horizontal">
          {{#foreach posts limit="10"}}
            {{> "post-row"}}
          {{/foreach}}
        </div>

      </div>
    </article>

    {{> "sidebar"}}

  </div>
</main>
