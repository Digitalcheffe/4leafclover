{
    "name": "4leafclover",
    "description": "Bold high-contrast Ghost theme with horizontal feed, sidebar, and deep customization.",
    "version": "1.2.1",
    "keywords": ["ghost-theme"],
    "private": true,
    "engines": {
        "ghost": ">=6.0.0"
    },
    "scripts": {
        "dev": "postcss src/main.css -o assets/built/main.css --watch",
        "build": "postcss src/main.css -o assets/built/main.css --env production",
        "pack": "node scripts/pack.js",
        "gscan": "gscan ."
    },
    "devDependencies": {
        "gscan": "^4.0.0",
        "autoprefixer": "^10.4.0",
        "postcss": "^8.4.0",
        "postcss-cli": "^11.0.0",
        "cssnano": "^7.0.0"
    },
    "author": {
        "name": "Digitalcheffe",
        "email": "digitalcheffe@outlook.com",
        "url": "https://painfully-useful.com"
    },
    "config": {
        "posts_per_page": 10,
        "image_sizes": {},
        "card_assets": true,
        "custom": {
            "background_color": {
                "type": "color",
                "default": "#0B0F14",
                "group": "colors",
                "description": "Page background color"
            },
            "surface_color": {
                "type": "color",
                "default": "#121823",
                "group": "colors",
                "description": "Card and panel background color"
            },
            "sticky_header": {
                "type": "boolean",
                "default": false,
                "group": "layout",
                "description": "Pin the header to the top while scrolling"
            },
            "sidebar_sticky": {
                "type": "boolean",
                "default": false,
                "group": "layout",
                "description": "Stick the sidebar in place on desktop while scrolling"
            },
            "social_links_extra": {
                "type": "text",
                "default": "",
                "group": "sidebar",
                "description": "Extra social icons. Format: Platform:URL, Platform:URL"
            },
            "cta_text": {
                "type": "text",
                "default": "Join free for updates",
                "group": "sidebar",
                "description": "Sidebar signup CTA headline"
            },
            "cta_subtext": {
                "type": "text",
                "default": "No spam. Just the good stuff.",
                "group": "sidebar",
                "description": "Sidebar signup CTA subtext"
            },
            "contact_webhook_url": {
                "type": "text",
                "default": "",
                "group": "contact",
                "title": "Contact form webhook URL",
                "description": "POST form submissions to this URL (n8n, Zapier, etc.)"
            },
            "contact_success_message": {
                "type": "text",
                "default": "Thanks \u2014 your message has been sent!",
                "group": "contact",
                "title": "Contact success message",
                "description": "Message shown after successful submission"
            },
            "contact_error_message": {
                "type": "text",
                "default": "Sorry \u2014 something went wrong. Please try again later.",
                "group": "contact",
                "title": "Contact error message",
                "description": "Message shown if the submission fails"
            },
            "home_hero_logo": {
                "type": "image",
                "default": "",
                "group": "homepage",
                "title": "Home hero overlay logo",
                "description": "Logo overlaid on the homepage hero image"
            },
            "show_home_intro": {
                "type": "boolean",
                "default": true,
                "group": "homepage",
                "description": "Show the homepage intro content"
            },
            "page_bridge_text": {
                "type": "text",
                "default": "Field:Notes",
                "group": "homepage",
                "title": "Page bridge text",
                "description": "Bridge text between hero and feed. Format: Left:Right"
            },
            "footer_bridge_text": {
                "type": "text",
                "default": "Stay Curious:Stay Useful",
                "group": "footer",
                "title": "Footer bridge text",
                "description": "Bridge text above the footer. Format: Left:Right"
            }
        }
    }
}
