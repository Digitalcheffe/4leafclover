{{!< default}}

{{#post}}

<main class="fs-main">
<div class="fs-grid">
    <article class="fs-content-card">
      <div class="fs-content-wrap">
        {{> "content-header"}}

      {{#if @page.show_title_and_feature_image}}
      {{#if feature_image}}
      <figure class="fs-post-feature">
        <img src="{{img_url feature_image size="l"}}" alt="{{title}}">
      </figure>
      {{/if}}
      {{/if}}
<section class="gh-content">
        {{#match slug "contact"}}
          {{> "contact-form"}}
        {{/match}}
        {{content}}
      </section>
      </div>
    </article>

    {{> "sidebar"}}
  </div>
</main>

{{/post}}
