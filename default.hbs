<!DOCTYPE html>
<html lang="{{@site.locale}}" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{meta_title}}</title>

  {{ghost_head}}
  <link rel="stylesheet" href="{{asset "built/main.css"}}">

  {{! Theme Custom Settings → override key CSS variables }}
  <style>
    :root {
	      {{#if @custom.background_color}}--bg: {{@custom.background_color}};{{/if}}
	      {{#if @custom.surface_color}}--surface: {{@custom.surface_color}};{{/if}}
	      {{#if @site.accent_color}}--accent: {{@site.accent_color}};{{/if}}
      --accent2: var(--accent);
      --pop: var(--accent);
    }

  </style>
</head>

<body>
  {{> "site-header"}}

  <div class="fs-container">
    {{{body}}}
  </div>

  {{> "site-footer"}}

  {{> "search-overlay"}}
  <script src="{{asset "built/main.js"}}"></script>
  {{ghost_foot}}
</body>
</html>
